# Required for OpenAI-backed agent work.
OPENAI_API_KEY=your_key_here

# Shared fallback model. Role-specific values can override this later.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_CODE_MODEL=gpt-4.1
OPENAI_REPAIR_MODEL=gpt-4.1
OPENAI_ANSWER_MODEL=gpt-4.1-mini

OPENAI_TIMEOUT_SECONDS=90
OPENAI_MAX_RETRIES=2

# Optional LangSmith tracing/evaluation learning track.
# Install with:
# .\.venv\Scripts\python.exe -m pip install -r requirements-tracing.txt
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_PROJECT=ai-analyst-dev
# Set only if your LangSmith account uses a regional/self-hosted endpoint.
LANGSMITH_ENDPOINT=

# Optional Kaggle dataset imports. You can also use `kaggle auth login`
# or place the official kaggle.json token file in your Kaggle config folder.
# `KAGGLE_API_TOKEN` may be the kaggle.json content or `username:key`.
KAGGLE_API_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=
